{
  "name": "otedama",
  "version": "0.6.0",
  "description": "Professional P2P Mining Pool & DEX Platform Ver0.6 - BTC-Only Payouts, 1% Mining Fee + 0.5% Conversion Fee, 13 currencies, 50+ languages",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --inspect index.js",
    "test": "node test/simple-test.js",
    "test:run": "node test/run-tests.js",
    "build": "echo 'No build step required - single file architecture'",
    "docker:build": "docker build -t otedama:0.6.0 .",
    "docker:run": "docker run -d --name otedama-v06 -p 8080:8080 -p 3333:3333 otedama:0.6.0",
    "docker:deploy": "docker-compose up -d",
    "install:windows": "deploy/install-windows.bat",
    "install:unix": "bash deploy/install.sh",
    "deploy": "bash deploy/deploy.sh",
    "status": "node index.js --help",
    "health": "curl -s http://localhost:8080/api/health || echo 'Server not running'"
  },
  "keywords": [
    "mining",
    "pool", 
    "cryptocurrency",
    "bitcoin",
    "btc",
    "btc-only",
    "auto-conversion",
    "ravencoin",
    "ethereum",
    "monero",
    "dex",
    "defi",
    "p2p",
    "stratum",
    "gpu",
    "cpu",
    "asic",
    "blockchain",
    "web3",
    "trading",
    "exchange",
    "multilingual",
    "mobile",
    "pwa",
    "performance",
    "low-fee",
    "hourly-payouts",
    "ver06"
  ],
  "author": {
    "name": "Otedama Team",
    "email": "team@otedama.com",
    "url": "https://otedama.com"
  },
  "license": "MIT",
  "homepage": "https://otedama.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/otedama/otedama.git"
  },
  "bugs": {
    "url": "https://github.com/otedama/otedama/issues",
    "email": "support@otedama.com"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/otedama"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "ws": "^8.16.0",
    "node-fetch": "^3.3.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {},
  "peerDependencies": {},
  "optionalDependencies": {},
  "bundledDependencies": [],
  "private": false,
  "workspaces": [],
  "config": {
    "version": "0.6.0",
    "mining_fee": "1% of minimum payout",
    "conversion_fee": "0.5% BTC conversion",
    "payout_currency": "BTC only",
    "supported_currencies": 13,
    "supported_algorithms": 10,
    "supported_languages": 50,
    "mobile_support": true,
    "dex_integrated": true,
    "btc_only_payouts": true
  },
  "os": [
    "win32",
    "darwin", 
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "files": [
    "index.js",
    "README.md",
    "LICENSE",
    "otedama.json",
    "deploy/",
    "web/",
    "mobile/",
    "test/simple-test.js",
    "test/run-tests.js",
    "Dockerfile",
    "docker-compose.yml"
  ],
  "directories": {
    "test": "test",
    "doc": "docs"
  },
  "bin": {
    "otedama": "./index.js"
  },
  "preferGlobal": true,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "overrides": {},
  "packageManager": "npm@10.0.0",
  "volta": {
    "node": "18.19.0"
  }
