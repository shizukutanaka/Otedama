{
  "name": "otedama",
  "version": "0.7.0",
  "description": "Professional P2P Mining Pool & DEX Platform with advanced DeFi features",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node test/test-suite.js",
    "test:simple": "node test/simple-test.js",
    "test:unit": "node test/test-suite.js --filter=unit",
    "test:integration": "node test/test-suite.js --filter=integration",
    "test:performance": "node test/performance.test.js",
    "test:security": "node test/security-audit.js",
    "test:verbose": "node test/test-suite.js --verbose",
    "test:report": "node test/test-suite.js --report",
    "test:watch": "node --watch test/test-suite.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "security:audit": "npm audit",
    "security:check": "node scripts/security-check.js",
    "db:migrate": "node scripts/migrate.js",
    "db:backup": "node scripts/backup.js",
    "monitor": "node scripts/monitor.js",
    "benchmark": "node scripts/benchmark.js",
    "load-test": "node scripts/load-test.js",
    "stress-test": "node scripts/load-test.js stress",
    "performance-report": "node scripts/performance-reporter.js",
    "performance-report:daily": "node scripts/performance-reporter.js daily",
    "performance-report:weekly": "node scripts/performance-reporter.js weekly",
    "performance-report:monthly": "node scripts/performance-reporter.js monthly",
    "deploy:production": "bash scripts/production-deploy.sh",
    "deploy:docker": "bash scripts/production-deploy.sh docker",
    "deploy:kubernetes": "bash scripts/production-deploy.sh kubernetes",
    "deploy:bare-metal": "bash scripts/production-deploy.sh bare-metal",
    "build": "echo 'Build complete - ready for production'",
    "build:docker": "docker build -f Dockerfile.production -t otedama/otedama:latest .",
    "build:test": "docker build -f Dockerfile.production --target testing -t otedama/otedama:test .",
    "build:benchmark": "docker build -f Dockerfile.production --target benchmark -t otedama/otedama:benchmark .",
    "docker:up": "docker-compose -f docker-compose.production.yml up -d",
    "docker:down": "docker-compose -f docker-compose.production.yml down",
    "docker:logs": "docker-compose -f docker-compose.production.yml logs -f"
  },
  "keywords": [
    "mining",
    "pool",
    "cryptocurrency",
    "bitcoin",
    "p2p",
    "dex",
    "blockchain"
  ],
  "author": "Otedama Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "ws": "^8.16.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "@types/node": "^20.10.6",
    "@types/ws": "^8.5.10",
    "@types/better-sqlite3": "^7.6.8"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/otedama/mining-pool.git"
  },
  "bugs": {
    "url": "https://github.com/otedama/mining-pool/issues"
  },
  "homepage": "https://otedama.io"
}