{
  "name": "otedama-mobile",
  "version": "0.6.0",
  "description": "Otedama Mobile Mining App - Professional PWA for cryptocurrency mining management",
  "main": "App.js",
  "type": "module",
  "scripts": {
    "start": "node App.js",
    "dev": "node --inspect App.js",
    "build": "echo 'PWA - No build required'",
    "serve": "python -m http.server 8080 || python3 -m http.server 8080",
    "install-pwa": "echo 'Open http://localhost:8080 in mobile browser and add to home screen'",
    "test": "echo 'Mobile tests integrated with main test suite'"
  },
  "keywords": [
    "mobile",
    "pwa",
    "mining",
    "cryptocurrency",
    "progressive-web-app",
    "ios",
    "android",
    "mobile-first",
    "responsive",
    "offline-support"
  ],
  "author": {
    "name": "Otedama Team", 
    "email": "mobile@otedama.com"
  },
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "iOS >= 12",
    "Android >= 6"
  ],
  "pwa": {
    "name": "Otedama Mining",
    "short_name": "Otedama",
    "description": "Professional cryptocurrency mining pool",
    "theme_color": "#2a5298",
    "background_color": "#1e3c72",
    "display": "standalone",
    "orientation": "portrait",
    "start_url": "/",
    "scope": "/",
    "icons": [
      {
        "src": "icon-192.png",
        "sizes": "192x192",
        "type": "image/png"
      },
      {
        "src": "icon-512.png", 
        "sizes": "512x512",
        "type": "image/png"
      }
    ]
  }
}
