# Otedama 環境設定
# 最高優先度機能対応版

# === プール基本設定 ===
POOL_ADDRESS=YOUR_WALLET_ADDRESS_HERE
POOL_FEE=0
POOL_DIFFICULTY=1

# === Stratum V2 設定 ===
STRATUM_V2_PORT=3334
ENABLE_ENCRYPTION=true
ENABLE_JOB_NEGOTIATION=true

# === 従来Stratum (互換性用) ===
STRATUM_PORT=3333

# === アルゴリズム設定 ===
SUPPORTED_ALGORITHMS=randomx,kawpow,sha256d,ethash
ENABLE_AUTO_SWITCHING=true
PROFIT_SWITCH_THRESHOLD=5

# === ネットワーク設定 ===
P2P_PORT=4334
WEB_UI_PORT=3001
API_PORT=8081

# === リアルタイム機能 ===
ENABLE_REALTIME_REVENUE=true
REVENUE_UPDATE_INTERVAL=30000
ELECTRICITY_COST=0.12

# === 自動設定 ===
ENABLE_ONE_CLICK_SETUP=true

# === ブロックチェーン RPC 設定 ===
# Bitcoin
BTC_RPC_URL=http://localhost:8332
BTC_RPC_USER=rpcuser
BTC_RPC_PASSWORD=rpcpassword

# Monero
XMR_RPC_URL=http://localhost:18081
XMR_RPC_USER=
XMR_RPC_PASSWORD=

# Ravencoin
RVN_RPC_URL=http://localhost:8766
RVN_RPC_USER=rpcuser
RVN_RPC_PASSWORD=rpcpassword

# Ethereum Classic
ETC_RPC_URL=http://localhost:8545
ETC_RPC_USER=
ETC_RPC_PASSWORD=

# === P2P ネットワーク ===
BOOTSTRAP_NODES=
MAX_PEERS=50

# === セキュリティ ===
ENABLE_DDoS_PROTECTION=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# === 通知・アラート ===
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=http://localhost:3000/alerts

# === キャッシュ設定 ===
CACHE_PORT=6379
CACHE_MAX_MEMORY=268435456

# === ログ設定 ===
DEBUG=false
LOG_LEVEL=info

# === モニタリング ===
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090