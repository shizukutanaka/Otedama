# Otedama Environment Configuration Example
# Copy this file to .env and update with your values

# Wallet Configuration
OTEDAMA_WALLET=YOUR_WALLET_ADDRESS_HERE
OTEDAMA_CURRENCY=RVN
OTEDAMA_WORKER=worker1

# Network Ports
OTEDAMA_P2P_PORT=8333
OTEDAMA_API_PORT=8080
OTEDAMA_STRATUM_PORT=3333

# Network Settings
OTEDAMA_P2P_ENABLED=true
OTEDAMA_API_ENABLED=true
OTEDAMA_API_HOST=0.0.0.0

# Mining Settings
OTEDAMA_MINING_ENABLED=true
OTEDAMA_THREADS=0
OTEDAMA_PROFIT_SWITCHING=false

# Data Storage
OTEDAMA_DATA_DIR=./data
OTEDAMA_LOG_LEVEL=info

# Pool Settings
OTEDAMA_POOL_FEE=0
OTEDAMA_PAYMENT_INTERVAL=3600
OTEDAMA_MINIMUM_PAYOUT=0.01
OTEDAMA_CONFIRMATIONS=10

# Docker Settings (for docker-compose)
WALLET_ADDRESS=YOUR_WALLET_ADDRESS_HERE
CURRENCY=RVN
LOG_LEVEL=info
GRAFANA_PASSWORD=admin

# External Pool Connection (optional)
# OTEDAMA_POOL_URL=pool.example.com
# OTEDAMA_POOL_PORT=3333
# OTEDAMA_POOL_USER=wallet.worker
# OTEDAMA_POOL_PASS=x

# API Security (optional)
# OTEDAMA_API_KEY=your-secret-api-key

# External API Keys
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key
# OTEDAMA_API_CORS=true

# Seed Nodes (optional)
# OTEDAMA_SEED_NODES=seed1.otedama.network:8333,seed2.otedama.network:8333
